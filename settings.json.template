{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Bash(gradlew *)",
      "Bash(./gradlew *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(docker compose *)",
      "Bash(docker exec *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(update *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Edit(**/.claude/**)",
      "Edit(**)",
      "Write",
      "Write(**/.claude/**)",
      "Write(**)",
      "MultiEdit",
      "MultiEdit(**)",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "AskUserQuestion",
      "Agent",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_hover",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_network_requests",
      "mcp__playwright__browser_navigate_back",
      "mcp__playwright__browser_drag",
      "mcp__playwright__browser_drop",
      "mcp__playwright__browser_file_upload",
      "mcp__playwright__browser_handle_dialog",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_network_request",
      "mcp__playwright__browser_run_code_unsafe",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "ToolSearch",
      "Skill"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf C:/Users)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(DROP TABLE*)",
      "Bash(DROP DATABASE*)",
      "Bash(taskkill //F //PID 0)",
      "Bash(format *)",
      "Write(__CLAUDE_HOME__/state/operator-ledger/**)",
      "Edit(__CLAUDE_HOME__/state/operator-ledger/**)",
      "MultiEdit(__CLAUDE_HOME__/state/operator-ledger/**)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "__CLAUDE_HOME__"
    ],
    "mode": "bypassPermissions"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/prompt/skill_match.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/prompt/context_load.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/prompt/debate_trigger.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/prompt/mode_detector.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/pre_tool/guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/pre_tool/pr_squash_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/pre_tool/project_branch_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": []
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/pre_tool/dart_strict_type_advisor.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/pre_tool/handoff_drift_gate.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/pre_tool/critic_policy_advisor.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/pre_tool/agent_depth_guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/post_tool/reviewer.py"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/tool/rationalization.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/post_tool/agent_invocation_audit.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/post_tool/skill_candidate_extractor.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/post_tool/agent_outcome_audit.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/stop/response_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/stop/learner.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/stop/autopilot_continue.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/session/init.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python __CLAUDE_HOME__/scripts/handlers/notification/on_notification.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enableWorkflows": true,
  "statusLine": {
    "type": "command",
    "command": "python __CLAUDE_HOME__/scripts/cli/hud.py"
  },
  "enabledPlugins": {
    "dx@ykdojo": true
  },
  "extraKnownMarketplaces": {
    "ykdojo": {
      "source": {
        "source": "github",
        "repo": "ykdojo/claude-code-tips"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "filesystem": {
      "allowWrite": [
        "__CLAUDE_HOME__/state/operator-ledger/*/"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "ultracode": true,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "light-daltonized",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}